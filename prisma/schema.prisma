generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum OnboardingState {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MemberRole {
  MEMBER
  ADMIN
}

enum MatchStatus {
  PROPOSED
  PRESENTED
  ACCEPTED
  ACTIVE
  COMPLETED
  DECLINED
}

enum MessageType {
  TEXT
  VOICE_NOTE
}

enum FeedbackRating {
  POSITIVE
  NEGATIVE
}

enum SignalStatus {
  DRAFT
  LIVE
  CLOSED
  PUBLISHED
}

enum SignalCategory {
  AI_STRATEGY
  KOREA_TACTICAL
  LEADERSHIP
  WILDCARD
  SYNTHESIS
}

enum SignalAnswer {
  A
  B
  C
  D
  E
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MatchTier {
  PLATINUM
  GOLD
  SILVER
  CURIOUS
  SKIP
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  AWAY
}

enum XrayStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum FeedbackQuestionKey {
  THE_GIFT
  THE_SPARK
  THE_FORWARD
  THE_COFFEE
  THE_BRIDGE
}

// ─── Models ──────────────────────────────────────────────

model Member {
  id               String          @id @default(cuid())
  clerkId          String          @unique
  email            String          @unique
  memberNumber     Int?            @unique
  firstName        String
  lastName         String
  imageUrl         String?
  customPhotoUrl   String?
  bio              String?
  headline         String?
  knownFor         String?
  company          String?
  jobTitle         String?
  linkedinUrl      String?
  phone            String?
  // ── 5-Dimension Superpower ──
  spDomain         String?         // Tech domain (e.g. "AI & Machine Learning")
  spAction         String?         // Specific action (e.g. "Scaling Teams")
  spScale          String?         // Scale (e.g. "Large team (50-200)")
  spStage          String?         // Company stage (e.g. "Series C-D")
  spGeo            String?         // Geography (e.g. "US ↔ Korea")
  spDomainCustom   String?         // Custom domain if "+ Other" selected
  spActionCustom   String?         // Custom action if "+ Custom" selected
  spGeoCustom      String?         // Custom geography if "+ Other" selected

  // ── Legacy keyword fields (kept for backward compat) ──
  superpowers      String[]
  superpowerDetails String[]

  // ── Conversational Questions (Q1-Q3) ──
  knownForDetail   String?         // Q1: "What's the one thing you're known for at work?"
  adviceSeeking    String?         // Q2: "If you could get advice from anyone..."
  passionTopic     String?         // Q3: "What's a topic you could talk about for hours?"

  // ── Typed Challenge System (deprecated — kept for existing member data) ──
  challengeType1   String?         // e.g. "technical", "leadership", "org", "career", "intro"
  challengeSpec1   String?         // Specific challenge selected
  challengeType2   String?
  challengeSpec2   String?

  // ── Legacy challenge fields ──
  challenges       String[]
  challengeDetails  String[]

  dreamConnection  String?
  dreamConnectionRefined String?
  preferredLang    String          @default("en")
  superpowersKr    String[]
  superpowerDetailsKr String[]
  challengesKr     String[]
  challengeDetailsKr String[]
  dreamConnectionKr String?
  dreamConnectionRefinedKr String?
  cardCompletedAt  DateTime?
  // ── Elev8 Titles (earned through positive peer votes) ──
  elev8Titles      String[]        // e.g. ["architect", "advisor", "connector"]
  // ── Living Credential fields ──
  superpowerUpdatedAt  DateTime?       // When superpower was last updated
  peerRecognitionCount Int         @default(0) // Cumulative positive peer recommendations
  lastActiveAt         DateTime?       // Last meaningful platform activity
  superpowerHistory    String[]        // JSON strings: ["{\"title\":\"...\",\"date\":\"...\"}"]
  onboardingState  OnboardingState @default(NOT_STARTED)
  onboardingStep   Int             @default(0)
  passwordHash     String?
  role             MemberRole      @default(MEMBER)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  matchesAsMember1    Match[]              @relation("MatchMember1")
  matchesAsMember2    Match[]              @relation("MatchMember2")
  messages            Message[]
  feedback            Feedback[]
  signalVotes         SignalVote[]
  suggestions         SignalSuggestion[]
  xrayProfiles        XrayProfile[]
  confidenceScore     ConfidenceScore?
  availability        MemberAvailability?
  exchangeFeedback    ExchangeFeedback[]

  @@index([clerkId])
  @@index([email])
}

model Match {
  id               String      @id @default(cuid())
  member1Id        String
  member2Id        String
  status           MatchStatus @default(PROPOSED)
  curatorNote      String?
  matchReason      String?
  matchReasonKr    String?
  matchedAt        DateTime?
  presentedAt      DateTime?
  acceptedAt       DateTime?
  completedAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  member1          Member             @relation("MatchMember1", fields: [member1Id], references: [id])
  member2          Member             @relation("MatchMember2", fields: [member2Id], references: [id])
  messages         Message[]
  feedback         Feedback[]
  matchScore       MatchScore?
  exchangeFeedback ExchangeFeedback[]

  @@unique([member1Id, member2Id])
  @@index([member1Id])
  @@index([member2Id])
  @@index([status])
}

model Message {
  id           String      @id @default(cuid())
  content      String
  type         MessageType @default(TEXT)
  voiceNoteUrl String?
  matchId      String
  senderId     String
  createdAt    DateTime    @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender Member @relation(fields: [senderId], references: [id])

  @@index([matchId])
}

model Feedback {
  id       String         @id @default(cuid())
  rating   FeedbackRating
  comment  String?
  matchId  String
  memberId String
  createdAt DateTime      @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id])

  @@unique([matchId, memberId])
  @@index([matchId])
}

// ─── Signal (Peer Survey) ───────────────────────────────

model SignalQuestion {
  id              String         @id @default(cuid())
  signalNumber    Int            @unique
  question        String
  category        SignalCategory @default(WILDCARD)
  status          SignalStatus   @default(DRAFT)
  optionA         String
  optionB         String
  optionC         String
  optionD         String
  optionE         String
  questionKr      String?
  optionAKr       String?
  optionBKr       String?
  optionCKr       String?
  optionDKr       String?
  optionEKr       String?
  headlineInsight String?
  voteDeadline    DateTime?
  publishedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  votes SignalVote[]

  @@index([status])
  @@index([signalNumber])
}

model SignalVote {
  id                String       @id @default(cuid())
  answer            SignalAnswer
  why               String?
  questionId        String
  memberId          String
  createdAt         DateTime     @default(now())
  resultEmailSentAt DateTime?

  question SignalQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  member   Member         @relation(fields: [memberId], references: [id])

  @@unique([questionId, memberId])
  @@index([questionId])
  @@index([memberId])
}

model SignalSuggestion {
  id               String           @id @default(cuid())
  rawQuestion      String
  context          String?
  polishedQuestion String?
  suggestedOptions String?          // JSON string of 5 options
  status           SuggestionStatus @default(PENDING)
  memberId         String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  member Member @relation(fields: [memberId], references: [id])

  @@index([status])
  @@index([memberId])
}

model AccessRequest {
  id          String              @id @default(cuid())
  name        String
  email       String
  linkedinUrl String
  status      AccessRequestStatus @default(PENDING)
  note        String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status])
  @@index([email])
}

// ─── Admin Audit Log ─────────────────────────────────────────────

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String
  adminEmail  String
  action      String   // e.g. "ACCESS_REQUEST_APPROVED", "SIGNAL_PUBLISHED"
  targetId    String?  // e.g. accessRequest.id or signal signalNumber
  targetLabel String?  // human-readable: "John Kim (john@co.com)" or "Signal #5"
  detail      String?  // JSON string with extra context
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@index([action])
}

// ─── Superpower Engine: Xray & Scoring ──────────────────

model XrayProfile {
  id                String     @id @default(cuid())
  memberId          String
  linkedinUrl       String
  status            XrayStatus @default(PENDING)
  rawData           Json?
  summary           String?
  summaryKr         String?
  linkedinData      Json?       // Raw Enrich Layer API response (cached)
  linkedinFetchedAt DateTime?   // When LinkedIn data was last fetched
  analyzedAt        DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  member       Member        @relation(fields: [memberId], references: [id])
  bucketScores BucketScore[]

  @@index([memberId])
}

model BucketScore {
  id            String   @id @default(cuid())
  xrayProfileId String
  bucket        String   // "career_trajectory" | "domain_expertise" | "leadership" | "innovation" | "network" | "growth_potential"
  score         Int      // 0-100
  evidence      String[]
  highlights    String[]
  createdAt     DateTime @default(now())

  xrayProfile XrayProfile @relation(fields: [xrayProfileId], references: [id], onDelete: Cascade)

  @@unique([xrayProfileId, bucket])
  @@index([xrayProfileId])
}

model ConfidenceScore {
  id            String   @id @default(cuid())
  memberId      String   @unique
  selfDeclared  Float    @default(0)
  xrayVerified  Float    @default(0)
  peerValidated Float    @default(0)
  composite     Float    @default(0)
  updatedAt     DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id])
}

model MatchScore {
  id               String    @id @default(cuid())
  matchId          String    @unique
  relevanceScore   Float
  reciprocityScore Float
  contextScore     Float
  totalScore       Float
  tier             MatchTier
  reasoning        String?
  reasoningKr      String?
  createdAt        DateTime  @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model ExchangeFeedback {
  id          String             @id @default(cuid())
  matchId     String
  memberId    String
  questionKey FeedbackQuestionKey
  response    String
  createdAt   DateTime           @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id])

  @@unique([matchId, memberId, questionKey])
  @@index([matchId])
}

model MemberAvailability {
  id             String             @id @default(cuid())
  memberId       String             @unique
  status         AvailabilityStatus @default(AVAILABLE)
  timezone       String             @default("Asia/Seoul")
  availableSlots Json?
  nextAvailable  DateTime?
  updatedAt      DateTime           @updatedAt

  member Member @relation(fields: [memberId], references: [id])
}

// ─── Waitlist ────────────────────────────────────────────

model Waitlist {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  company     String?
  role        String?
  email       String   @unique
  phone       String?
  createdAt   DateTime? @default(now())
  linkedinUrl String?
}

// ─── AI-Generated Signal Suggestions (from member challenges) ───

model AiSignalSuggestion {
  id            String   @id @default(cuid())
  question      String
  questionKr    String?
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  optionE       String
  rationale     String
  sourceThemes  String[]
  status        SuggestionStatus @default(PENDING)
  adminNotified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

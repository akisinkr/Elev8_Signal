generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum OnboardingState {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MemberRole {
  MEMBER
  ADMIN
}

enum MatchStatus {
  PROPOSED
  PRESENTED
  ACCEPTED
  ACTIVE
  COMPLETED
  DECLINED
}

enum MessageType {
  TEXT
  VOICE_NOTE
}

enum FeedbackRating {
  POSITIVE
  NEGATIVE
}

enum SignalStatus {
  DRAFT
  LIVE
  CLOSED
  PUBLISHED
}

enum SignalCategory {
  AI_STRATEGY
  KOREA_TACTICAL
  LEADERSHIP
  WILDCARD
  SYNTHESIS
}

enum SignalAnswer {
  A
  B
  C
  D
  E
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Models ──────────────────────────────────────────────

model Member {
  id               String          @id @default(cuid())
  clerkId          String          @unique
  email            String          @unique
  memberNumber     Int?            @unique
  firstName        String
  lastName         String
  imageUrl         String?
  customPhotoUrl   String?
  bio              String?
  headline         String?
  knownFor         String?
  company          String?
  jobTitle         String?
  linkedinUrl      String?
  // ── 5-Dimension Superpower ──
  spDomain         String?         // Tech domain (e.g. "AI & Machine Learning")
  spAction         String?         // Specific action (e.g. "Scaling Teams")
  spScale          String?         // Scale (e.g. "Large team (50-200)")
  spStage          String?         // Company stage (e.g. "Series C-D")
  spGeo            String?         // Geography (e.g. "US ↔ Korea")
  spDomainCustom   String?         // Custom domain if "+ Other" selected
  spActionCustom   String?         // Custom action if "+ Custom" selected

  // ── Legacy keyword fields (kept for backward compat) ──
  superpowers      String[]
  superpowerDetails String[]

  // ── Typed Challenge System ──
  challengeType1   String?         // e.g. "technical", "leadership", "org", "career", "intro"
  challengeSpec1   String?         // Specific challenge selected
  challengeType2   String?
  challengeSpec2   String?

  // ── Legacy challenge fields ──
  challenges       String[]
  challengeDetails  String[]

  dreamConnection  String?
  dreamConnectionRefined String?
  preferredLang    String          @default("en")
  superpowersKr    String[]
  superpowerDetailsKr String[]
  challengesKr     String[]
  challengeDetailsKr String[]
  dreamConnectionKr String?
  dreamConnectionRefinedKr String?
  cardCompletedAt  DateTime?
  onboardingState  OnboardingState @default(NOT_STARTED)
  onboardingStep   Int             @default(0)
  passwordHash     String?
  role             MemberRole      @default(MEMBER)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  matchesAsMember1 Match[]      @relation("MatchMember1")
  matchesAsMember2 Match[]      @relation("MatchMember2")
  messages         Message[]
  feedback         Feedback[]
  signalVotes      SignalVote[]
  suggestions      SignalSuggestion[]

  @@index([clerkId])
}

model Match {
  id          String      @id @default(cuid())
  member1Id   String
  member2Id   String
  status      MatchStatus @default(PROPOSED)
  curatorNote String?
  matchedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  member1  Member     @relation("MatchMember1", fields: [member1Id], references: [id])
  member2  Member     @relation("MatchMember2", fields: [member2Id], references: [id])
  messages Message[]
  feedback Feedback[]

  @@index([member1Id])
  @@index([member2Id])
}

model Message {
  id           String      @id @default(cuid())
  content      String
  type         MessageType @default(TEXT)
  voiceNoteUrl String?
  matchId      String
  senderId     String
  createdAt    DateTime    @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender Member @relation(fields: [senderId], references: [id])

  @@index([matchId])
}

model Feedback {
  id       String         @id @default(cuid())
  rating   FeedbackRating
  comment  String?
  matchId  String
  memberId String
  createdAt DateTime      @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id])

  @@unique([matchId, memberId])
  @@index([matchId])
}

// ─── Signal (Peer Survey) ───────────────────────────────

model SignalQuestion {
  id              String         @id @default(cuid())
  signalNumber    Int            @unique
  question        String
  category        SignalCategory @default(WILDCARD)
  status          SignalStatus   @default(DRAFT)
  optionA         String
  optionB         String
  optionC         String
  optionD         String
  optionE         String
  questionKr      String?
  optionAKr       String?
  optionBKr       String?
  optionCKr       String?
  optionDKr       String?
  optionEKr       String?
  headlineInsight String?
  voteDeadline    DateTime?
  publishedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  votes SignalVote[]

  @@index([status])
  @@index([signalNumber])
}

model SignalVote {
  id                String       @id @default(cuid())
  answer            SignalAnswer
  why               String?
  questionId        String
  memberId          String
  createdAt         DateTime     @default(now())
  resultEmailSentAt DateTime?

  question SignalQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  member   Member         @relation(fields: [memberId], references: [id])

  @@unique([questionId, memberId])
  @@index([questionId])
}

model SignalSuggestion {
  id               String           @id @default(cuid())
  rawQuestion      String
  context          String?
  polishedQuestion String?
  suggestedOptions String?          // JSON string of 5 options
  status           SuggestionStatus @default(PENDING)
  memberId         String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  member Member @relation(fields: [memberId], references: [id])

  @@index([status])
  @@index([memberId])
}

model AccessRequest {
  id          String              @id @default(cuid())
  name        String
  email       String
  linkedinUrl String
  status      AccessRequestStatus @default(PENDING)
  note        String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status])
  @@index([email])
}

// ─── AI-Generated Signal Suggestions (from member challenges) ───

model AiSignalSuggestion {
  id            String   @id @default(cuid())
  question      String
  questionKr    String?
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  optionE       String
  rationale     String
  sourceThemes  String[]
  status        SuggestionStatus @default(PENDING)
  adminNotified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}
